APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8088
APP_REQUEST_TIMEOUT_SECONDS=30
APP_BODY_LIMIT_MB=2

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgres://app:app@localhost:5432/app_db
DATABASE_MAX_CONNECTIONS=10

VALKEY_URL=redis://localhost:6379/0

JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

RUST_LOG=info,tower_http=info,diesel=warn

